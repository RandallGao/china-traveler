---
interface Props {
  /** Use Astro.url.pathname so `base` matches highlight state */
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;

const sections: { slug: string; label: string; secondary?: boolean }[] = [
  { slug: "before-land/", label: "Before you land" },
  { slug: "payments/", label: "Payments" },
  { slug: "transport/", label: "Transport" },
  { slug: "rail/", label: "Rail" },
  { slug: "connectivity/", label: "Connectivity" },
  { slug: "appendix-tickets/", label: "Appendix: Tickets & events", secondary: true },
];

const homeHref = base;
const normalized = (p: string) => p.replace(/\/$/, "") || "/";
const isHome =
  normalized(currentPath) === normalized(homeHref) ||
  normalized(currentPath) === `${normalized(homeHref)}/index`;
---

<nav class="guide-nav" aria-label="Guide sections">
  <div class="guide-nav-inner">
    <p class="guide-nav-title">
      <a href={homeHref} aria-current={isHome ? "page" : undefined}>China guide — Shanghai first</a>
    </p>
    <div class="guide-nav-scroll">
      <ol class="guide-nav-list">
        {
          sections.map(({ slug, label, secondary }) => {
            const href = `${base}${slug}`;
            const active = normalized(currentPath) === normalized(href);
            return (
              <li class:list={{ "nav-secondary": secondary, "is-current": active }}>
                <a href={href} aria-current={active ? "page" : undefined}>
                  {label}
                </a>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</nav>
<style>
  .guide-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--border, #d9cfc0);
    background: var(--nav-surface, rgba(243, 239, 230, 0.82));
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 1px 0 var(--nav-line, rgba(28, 24, 20, 0.04));
  }
  .guide-nav-inner {
    max-width: 52rem;
    margin: 0 auto;
    padding: 0.85rem 1.25rem 0.95rem;
  }
  @media (min-width: 640px) {
    .guide-nav-inner {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }
  .guide-nav-title {
    margin: 0 0 0.65rem;
    font-family: var(--font-display, "Fraunces Variable", Georgia, serif);
    font-size: 1.02rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .guide-nav-title a {
    color: var(--text, #1c1814);
    text-decoration: none;
    transition: color 0.2s var(--ease-out, ease);
  }
  .guide-nav-title a:hover {
    color: var(--accent, #b8321a);
  }
  .guide-nav-title a[aria-current="page"] {
    color: var(--accent, #b8321a);
  }
  .guide-nav-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 0 -1.25rem;
    padding: 0 1.25rem 0.15rem;
    scrollbar-width: thin;
  }
  @media (min-width: 640px) {
    .guide-nav-scroll {
      margin: 0 -2rem;
      padding: 0 2rem 0.15rem;
    }
  }
  .guide-nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
    align-items: center;
  }
  .guide-nav-list li {
    margin: 0;
  }
  .guide-nav-list a {
    display: inline-block;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    font-family: var(--font-body, "Newsreader Variable", Georgia, serif);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text, #1c1814);
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background 0.2s var(--ease-out, ease),
      color 0.2s var(--ease-out, ease),
      border-color 0.2s var(--ease-out, ease),
      box-shadow 0.2s var(--ease-out, ease);
  }
  .guide-nav-list a:hover {
    background: var(--nav-pill-hover-bg, rgba(26, 92, 82, 0.08));
    color: var(--nav-pill-hover-color, var(--teal, #1a5c52));
  }
  .guide-nav-list .is-current a {
    font-weight: 600;
    color: #fff;
    background: var(--nav-pill-bg, linear-gradient(135deg, #b8321a 0%, #8f2815 100%));
    box-shadow: var(--nav-pill-glow, 0 2px 12px rgba(184, 50, 26, 0.25));
  }
  .guide-nav-list .is-current a:hover {
    color: #fff;
    background: var(--nav-pill-bg-hover, linear-gradient(135deg, #942818 0%, #752010 100%));
  }
  .nav-secondary {
    flex-basis: 100%;
    margin-top: 0.35rem;
    padding-top: 0.55rem;
    border-top: 1px dashed var(--border, #d9cfc0);
  }
  .nav-secondary a {
    font-size: 0.82rem;
    color: var(--nav-secondary, #6e655b);
  }
  .nav-secondary a:hover {
    color: var(--nav-pill-hover-color, var(--teal, #1a5c52));
    background: var(--nav-secondary-hover-bg, rgba(26, 92, 82, 0.06));
  }
  .nav-secondary.is-current a {
    color: #fff;
  }
</style>
