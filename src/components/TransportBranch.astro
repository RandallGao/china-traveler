---
import { getEntry, render } from "astro:content";

const metro = await getEntry("partials", "b-metro-heavy");
const general = await getEntry("partials", "b-general-transport");
if (!metro || !general) throw new Error("Missing transport partials");

const { Content: MetroContent } = await render(metro);
const { Content: GeneralContent } = await render(general);
---

<div id="transport-branch-root" class="transport-branch">
  <fieldset class="transport-branch-fieldset">
    <legend class="transport-branch-legend">How you’ll move in Shanghai</legend>
    <div class="transport-branch-options" role="presentation">
      <label class="transport-branch-label">
        <input type="radio" name="transport-branch" value="metro" checked />
        <span class="transport-branch-card">
          <span class="transport-branch-label-text">Shanghai / Metro-first days</span>
        </span>
      </label>
      <label class="transport-branch-label">
        <input type="radio" name="transport-branch" value="general" />
        <span class="transport-branch-card">
          <span class="transport-branch-label-text">Shanghai · Taxis, buses &amp; ride-hail first</span>
        </span>
      </label>
    </div>
  </fieldset>
  <div class="transport-panels">
    <div data-transport-panel="metro" class="transport-panel">
      <MetroContent />
    </div>
    <div data-transport-panel="general" class="transport-panel" hidden>
      <GeneralContent />
    </div>
  </div>
</div>

<script>
  import { initTransportBranch } from "../scripts/transport-branch";

  const root = document.getElementById("transport-branch-root");
  if (root) initTransportBranch(root);
</script>

<style>
  .transport-branch {
    margin: 1.5rem 0;
    padding: 0;
    border: 1px solid var(--border, #d9cfc0);
    border-radius: 10px;
    background: var(--bg-elevated, #faf7f0);
    box-shadow: var(--shadow-soft, 0 2px 20px rgba(28, 24, 20, 0.06));
    overflow: clip;
  }
  .transport-branch-fieldset {
    border: none;
    margin: 0;
    padding: 1rem 1rem 0.85rem;
    background: linear-gradient(180deg, var(--transport-fieldset-tint, rgba(26, 92, 82, 0.06)), transparent);
  }
  .transport-branch-legend {
    font-family: var(--font-display, "Fraunces Variable", Georgia, serif);
    font-weight: 650;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    padding: 0 0.15rem;
    margin-bottom: 0.65rem;
    color: var(--text, #1c1814);
  }
  .transport-branch-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  @media (min-width: 540px) {
    .transport-branch-options {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .transport-branch-label {
      flex: 1 1 calc(50% - 0.25rem);
      min-width: 12rem;
    }
  }
  .transport-branch-label {
    position: relative;
    display: block;
    cursor: pointer;
    margin: 0;
  }
  .transport-branch-label input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    margin: -1px;
    clip: rect(0, 0, 0, 0);
  }
  .transport-branch-card {
    display: flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    border: 2px solid var(--border, #d9cfc0);
    background: var(--card-surface, rgba(255, 255, 255, 0.55));
    transition:
      border-color 0.2s var(--ease-out, ease),
      background 0.2s var(--ease-out, ease),
      box-shadow 0.2s var(--ease-out, ease),
      transform 0.15s var(--ease-out, ease);
  }
  .transport-branch-label:hover .transport-branch-card {
    border-color: var(--transport-card-hover-border, rgba(26, 92, 82, 0.35));
    background: var(--card-surface-hover, rgba(255, 255, 255, 0.9));
  }
  .transport-branch-label input:focus-visible + .transport-branch-card {
    outline: 2px solid var(--teal, #1a5c52);
    outline-offset: 2px;
  }
  .transport-branch-label input:checked + .transport-branch-card {
    border-color: var(--accent, #b8321a);
    background: var(
      --card-checked-bg,
      linear-gradient(145deg, #fff 0%, rgba(184, 50, 26, 0.06) 100%)
    );
    box-shadow: var(--card-checked-ring, 0 0 0 1px rgba(184, 50, 26, 0.15));
  }
  .transport-branch-label:active .transport-branch-card {
    transform: scale(0.99);
  }
  @media (prefers-reduced-motion: reduce) {
    .transport-branch-card {
      transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    }
    .transport-branch-label:active .transport-branch-card {
      transform: none;
    }
  }
  .transport-branch-label-text {
    font-family: var(--font-body, "Newsreader Variable", Georgia, serif);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--text, #1c1814);
  }
  .transport-panels {
    padding: 0 1rem 1.15rem;
    border-top: 1px solid var(--border, #d9cfc0);
    margin-top: 0.85rem;
    padding-top: 1.1rem;
  }
  .transport-panel :global(h2) {
    font-family: var(--font-display, "Fraunces Variable", Georgia, serif);
    font-size: 1.12rem;
    font-weight: 600;
    margin-top: 0;
    color: var(--teal, #1a5c52);
  }
  .transport-panel :global(h3) {
    font-family: var(--font-display, "Fraunces Variable", Georgia, serif);
    font-size: 1rem;
    font-weight: 600;
  }
</style>
