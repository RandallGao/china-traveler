---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideNav from "../../components/GuideNav.astro";
import StageBanner from "../../components/StageBanner.astro";

const entry = await getEntry("guide", "transport");
if (!entry) {
  throw new Error("Missing guide entry: transport");
}

const { Content } = await render(entry);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lastReviewed={entry.data.lastReviewed}
>
  <GuideNav slot="nav" currentPath={Astro.url.pathname} />
  <article class="chapter">
    <StageBanner
      stage="After landing"
      status="In progress"
      capability="Mobility activated"
      nextLabel="Unlock high-speed rail (optional)"
      nextHref={`${base}rail/`}
    />
    <Content />
  </article>
</BaseLayout>
