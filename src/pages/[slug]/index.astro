---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GuideNav from "../../components/GuideNav.astro";

export async function getStaticPaths() {
  const entries = await getCollection("guide");
  return entries
    .filter((e) => e.slug !== "transport")
    .map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("guide", slug!);
if (!entry) {
  return Astro.redirect("/");
}

const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lastReviewed={entry.data.lastReviewed}
>
  <GuideNav slot="nav" currentPath={Astro.url.pathname} />
  <article class="chapter">
    <Content />
  </article>
</BaseLayout>
