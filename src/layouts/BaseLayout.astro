---
interface Props {
  title: string;
  description: string;
  /** ISO-ish date from content frontmatter (e.g. 2026-03-25) for article meta */
  lastReviewed?: string;
}

const { title, description, lastReviewed } = Astro.props;

const canonicalHref =
  Astro.site != null
    ? new URL(Astro.url.pathname, Astro.site).href
    : undefined;

const ogModified =
  lastReviewed != null && lastReviewed.length >= 10
    ? `${lastReviewed.slice(0, 10)}T12:00:00.000Z`
    : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {canonicalHref != null && <link rel="canonical" href={canonicalHref} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalHref != null && <meta property="og:url" content={canonicalHref} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogModified != null && <meta property="article:modified_time" content={ogModified} />}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot name="nav" />
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        <strong>Disclaimer:</strong> This guide is not legal, immigration, or financial advice.
        Procedures and apps change; always follow live app and venue rules.
      </p>
    </footer>
    <style is:global>
      :root {
        --bg: #faf9f7;
        --text: #1a1a1a;
        --muted: #5c5c5c;
        --accent: #0b5cab;
        --border: #e2ddd4;
        --nav-secondary: #6b6b6b;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial,
          sans-serif;
        line-height: 1.55;
        color: var(--text);
        background: var(--bg);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--accent);
        color: #fff;
        z-index: 100;
      }
      .skip-link:focus {
        left: 0.5rem;
      }
      #main {
        flex: 1;
        width: 100%;
        max-width: 40rem;
        margin: 0 auto;
        padding: 1rem 1.25rem 3rem;
      }
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 1rem 1.25rem 2rem;
        font-size: 0.85rem;
        color: var(--muted);
        max-width: 40rem;
        margin: 0 auto;
        width: 100%;
      }
      .site-footer strong {
        color: var(--text);
      }
      .chapter h2 {
        margin-top: 2rem;
        font-size: 1.15rem;
      }
      .chapter h2:first-child {
        margin-top: 0;
      }
      .chapter h3 {
        font-size: 1rem;
        margin-top: 1.25rem;
      }
      .chapter p,
      .chapter li {
        color: var(--text);
      }
      .chapter ul.checklist {
        list-style: none;
        padding-left: 0;
      }
      .chapter ul.checklist li {
        padding-left: 1.5rem;
        position: relative;
        margin-bottom: 0.5rem;
      }
      .chapter ul.checklist li::before {
        content: "☐";
        position: absolute;
        left: 0;
        color: var(--muted);
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
        margin: 1rem 0;
      }
      th,
      td {
        border: 1px solid var(--border);
        padding: 0.5rem 0.6rem;
        text-align: left;
        vertical-align: top;
      }
      th {
        background: #f0ebe3;
      }
    </style>
  </body>
</html>
