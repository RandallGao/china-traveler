# --- Production / GitHub Pages (see README “Deploy”) ---
# Origin only (no repo path):
PUBLIC_SITE_URL=https://YOURGITHUBUSERNAME.github.io
# Project Pages only — leading/trailing slashes matter (e.g. /china-traveler/):
PUBLIC_BASE_PATH=/YOUR-REPO-NAME/

# Root site (custom domain or user site with base /): leave PUBLIC_BASE_PATH unset or set to /
